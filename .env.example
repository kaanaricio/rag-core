# Minimal env for a real local folder-RAG test with OpenAI embeddings
# and in-memory Qdrant.
#
# Usage:
#   cp .env.example .env
#   edit .env
#   set -a; source .env; set +a

# Pick exactly one Qdrant mode.
RAG_CORE_QDRANT_LOCATION=:memory:
# RAG_CORE_QDRANT_URL=http://localhost:6333
# RAG_CORE_QDRANT_API_KEY=

# Collection / corpus defaults for ad-hoc local tests.
RAG_CORE_QDRANT_COLLECTION=rag_core_chunks
RAG_CORE_QDRANT_DIMENSION_AWARE_COLLECTION=true

# Dense embedding provider for real retrieval quality.
RAG_CORE_EMBEDDING_PROVIDER=openai
RAG_CORE_EMBEDDING_MODEL=text-embedding-3-small
RAG_CORE_EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=

# Optional reranking.
RAG_CORE_RERANKER_PROVIDER=none
# RAG_CORE_RERANKER_PROVIDER=cohere
# RAG_CORE_RERANKER_MODEL=rerank-v3.5
# COHERE_API_KEY=
# RERANKER_STRICT_PROVIDER=true

# Optional alternative providers.
# VOYAGE_API_KEY=
# ZEROENTROPY_API_KEY=

# Optional sparse model overrides.
# SPARSE_EMBEDDING_MODEL=Qdrant/bm25
# SPARSE_EMBEDDING_MODEL_BM25=Qdrant/bm25
# SPARSE_EMBEDDING_MODEL_SPLADE=prithivida/Splade_PP_en_v1

# Optional PDF Inspector controls.
# PDF_INSPECTOR_MODE=auto
# PDF_INSPECTOR_BINARY_PATH=
# PDF_INSPECTOR_TIMEOUT_MS=8000
# PDF_INSPECTOR_MAX_BYTES=52428800

# Optional OCR providers for scanned PDFs.
# MISTRAL_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
